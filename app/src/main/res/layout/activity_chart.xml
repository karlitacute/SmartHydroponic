<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainChart"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/verylightcoolgray"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/headerChart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Monitoring Chart"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_profile" />
    </LinearLayout>

    <ScrollView
        android:paddingBottom="0dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerChart"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_marginTop="0dp"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <HorizontalScrollView
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:background="@drawable/bg_filter_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:layout_width="0dp"
                    android:layout_height="50dp">

                    <!-- TEMPERATURE -->
                    <LinearLayout
                        android:id="@+id/btnTemp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_filter_active"
                        android:layout_marginEnd="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:src="@drawable/ic_temperature"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>

                        <TextView
                            android:text="Temperature"
                            android:textSize="12sp"
                            android:textColor="@color/green"
                            android:layout_marginStart="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- PH -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/btnPH"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_filter_inactive"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:src="@drawable/ic_water"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>

                        <TextView
                            android:text="Water pH"
                            android:textSize="12sp"
                            android:layout_marginStart="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- TDS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/btnTDS"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp"
                        android:background="@drawable/bg_filter_inactive"
                        android:layout_marginEnd="10dp">

                        <ImageView
                            android:src="@drawable/tds"
                            android:layout_width="16dp"
                            android:layout_height="16dp" />

                        <TextView
                            android:text="Water TDS"
                            android:textSize="12sp"
                            android:layout_marginStart="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- UV -->
                    <LinearLayout
                        android:id="@+id/btnUV"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_filter_inactive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:src="@drawable/uv"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>

                        <TextView
                            android:text="UV Light"
                            android:textSize="12sp"
                            android:layout_marginStart="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>

            <HorizontalScrollView
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/btn1jam"
                        style="@style/TimeButton.Active"
                        android:text="1 Jam"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:textAlignment="center"
                        android:layout_width="70dp"
                        android:layout_height="30dp"/>

                    <TextView
                        android:id="@+id/btn6jam"
                        style="@style/TimeButton.Inactive"
                        android:text="6 Jam"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:textAlignment="center"
                        android:layout_width="70dp"
                        android:layout_height="30dp"/>

                    <TextView
                        android:id="@+id/btn12jam"
                        style="@style/TimeButton.Inactive"
                        android:text="12 Jam"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:textAlignment="center"
                        android:layout_width="70dp"
                        android:layout_height="30dp"/>

                    <TextView
                        android:id="@+id/btn1hari"
                        style="@style/TimeButton.Inactive"
                        android:text="1 Hari"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:textAlignment="center"
                        android:layout_width="70dp"
                        android:layout_height="30dp"/>

                    <TextView
                        android:id="@+id/btn7hari"
                        style="@style/TimeButton.Inactive"
                        android:text="7 Hari"
                        android:textStyle="bold"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:textAlignment="center"
                        android:layout_width="70dp"
                        android:layout_height="30dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:text="Temperature Chart (°C)"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:text="Pump Control"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_marginTop="15dp"
                android:padding="20dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_summary"
                android:layout_width="match_parent"
                android:layout_height="100dp">

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Minimum"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="@color/black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="25.0 °c"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="08.00"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Rata - rata"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:textStyle="normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="28.2 °c"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="Hari ini"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="Maksimum"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:textStyle="normal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="31.0 °c"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="12.00"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="@color/black"
                        android:layout_marginTop="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:text="Data History"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="vertical"
                android:layout_marginTop="15dp"
                android:padding="16dp"
                android:background="@drawable/bg_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:src="@drawable/ic_temperature"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:text="Temperature"
                        android:textStyle="normal"
                        android:textSize="12sp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <!-- VALUE -->
                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="28.0 °c"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="23 April 2026 12.00"
                            android:textSize="12sp"
                            android:textStyle="normal"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_marginVertical="10dp"
                    android:background="@color/lightindigo"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"/>

                <!-- ITEM 2 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:src="@drawable/ic_water"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:text="Water pH"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:textColor="@color/black"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="6.5"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="23 April 2026 12.00"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:textStyle="normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_marginVertical="10dp"
                    android:background="@color/lightindigo"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"/>

                <!-- ITEM 3 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:src="@drawable/tds"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:text="Water TDS"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="700 ppm"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="23 April 2026 12.00"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:textStyle="normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_marginVertical="10dp"
                    android:background="@color/lightindigo"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"/>

                <!-- ITEM 4 -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:src="@drawable/uv"
                        android:layout_width="40dp"
                        android:layout_height="40dp"/>

                    <TextView
                        android:text="UV Light"
                        android:textSize="12sp"
                        android:textStyle="normal"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:text="3.2"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="23 April 2026 12.00"
                            android:textSize="12sp"
                            android:textStyle="normal"
                            android:textColor="@color/black"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/white"
        app:menu="@menu/menu_bottom"
        app:itemIconTint="@color/nav_color"
        app:itemTextColor="@color/nav_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>